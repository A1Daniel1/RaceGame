aws_region    = "us-east-1"
vpc_id        = "vpc-xxxxxxxxxxxxxxxxx"
subnet_ids    = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]
listener_arn  = "arn:aws:elasticloadbalancing:us-east-1:<account_id>:listener/app/ecs-express-gateway-alb/<alb_id>/<listener_id>"
ecr_image_uri = "<account_id>.dkr.ecr.us-east-1.amazonaws.com/auth-service:latest"
mongodb_uri   = "mongodb+srv://user:password@cluster.mongodb.net/racegame"
